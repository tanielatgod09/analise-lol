# ============================================================
# Variáveis de Ambiente — Sistema de Análise de Apostas LoL
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# --- Banco de Dados PostgreSQL ---
DATABASE_URL=postgresql://postgres:senha@localhost:5432/analise_lol
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=analise_lol
DATABASE_USER=postgres
DATABASE_PASSWORD=senha_segura

# --- API Riot Games ---
# Obtenha em: https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- API PandaScore ---
# Obtenha em: https://developers.pandascore.co/
PANDASCORE_API_KEY=seu_token_pandascore_aqui

# --- LoL Esports API ---
LOL_ESPORTS_API_KEY=0TvQnueqKa5mxJntVWt0w4LpLfEkrV1Ta8rQBb9Z

# --- TheOddsAPI (Odds de casas de apostas) ---
# Obtenha em: https://the-odds-api.com/
ODDS_API_KEY=sua_chave_theoddsapi_aqui

# --- Configurações da Aplicação ---
APP_ENV=development
APP_SECRET_KEY=chave_secreta_muito_segura_aqui
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Configurações de Cache ---
CACHE_TTL_SECONDS=300

# --- Configurações do Scheduler ---
DATA_UPDATE_INTERVAL_MINUTES=5
ODDS_UPDATE_INTERVAL_MINUTES=5

# --- Configurações de Machine Learning ---
ML_MODELS_PATH=./ml_models
ML_MIN_GAMES_FOR_PREDICTION=5

# --- Configurações de Apostas ---
MIN_EV_THRESHOLD=0.0
MIN_CONFIDENCE_THRESHOLD=0.65
MIN_HIGHLIGHT_CONFIDENCE=0.75

# --- Configurações de Monte Carlo ---
MONTE_CARLO_SIMULATIONS=10000

# --- Configurações de Log ---
LOG_LEVEL=INFO
LOG_FORMAT=json
